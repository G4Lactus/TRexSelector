if (requireNamespace("lintr", quietly = TRUE)) {
  options(
    lintr.linters = lintr::linters_with_defaults(
      object_name_linter = NULL,   # disable snake_case enforcement
      line_length_linter = lintr::line_length_linter(120L)
    )
  )
}
