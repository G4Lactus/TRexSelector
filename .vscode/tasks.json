{
    "version": "2.0.0",
    "tasks": [
        // Debug profile: Configure and build in separate debug directory
        {
            "type": "shell",
            "label": "CMake Full Build (Debug)",
            "command": "cmake",
            "args": [
                "-S", ".",
                "-B", "build/debug",
                "-DCMAKE_BUILD_TYPE=Debug",
                "&&", // Unix/macOS
                "cmake",
                "--build", "build/debug"
            ],
            "windows": {
                "args": [
                    "-S", ".",
                    "-B", "build/debug",
                    "-DCMAKE_BUILD_TYPE=Debug",
                    ";", // Windows
                    "cmake",
                    "--build", "build/debug"
                ]
            },
            "options": {"cwd": "${workspaceFolder}"},
            "group": {"kind": "build"},
            "problemMatcher": ["$gcc"],
            "detail": "CMake configure and build (Debug, separate directory)"
        },
        // Release profile: Single command for configure and build
        {
            "type": "shell",
            "label": "CMake Full Build (Release)",
            "command": "cmake",
            "args": [
                "-S", ".",
                "-B", "build/release",
                "-DCMAKE_BUILD_TYPE=Release",
                "&&", // Unix/macOS
                "cmake",
                "--build", "build/release"
            ],
            "windows": {
                "args": [
                    "-S", ".",
                    "-B", "build/release",
                    "-DCMAKE_BUILD_TYPE=Release",
                    ";", // Windows
                    "cmake",
                    "--build", "build/release"
                ]
            },
            "options": {"cwd": "${workspaceFolder}"},
            "group": {"kind": "build"},
            "problemMatcher": ["$gcc"],
            "detail": "CMake configure and build (Release, separate directory)"
        }
    ]
}
